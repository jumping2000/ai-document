# Application
APP_NAME="AI Document Platform"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-min-32-chars-change-in-production
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_docs
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480

# AI Models
DEFAULT_AI_MODEL=gpt-4o
DEFAULT_AI_PROVIDER=openai
# OpenAI / Anthropic / OpenRouter
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=
# Max output tokens for LLM responses (prevents truncated JSON).
# Lower values (<4096) risk cutting off structured output from requirement agents.
# Default: 16384
MAX_TOKENS=16384
# Ollama (local)
OLLAMA_URL=http://localhost:11434
OLLAMA_API_KEY=

# MCP / RAG
MCP_SERVER_URL=http://localhost:8001
MCP_API_KEY=your-mcp-api-key
MCP_TIMEOUT_SECONDS=30
MCP_MAX_RETRIES=3

# Workflow
WORKFLOW_MAX_RETRIES=3
WORKFLOW_QUALITY_THRESHOLD=0.75
WORKFLOW_TIMEOUT_MINUTES=60

# Document storage
DOCUMENTS_BASE_PATH=/app/documents
TEMPLATES_BASE_PATH=/app/app/templates

# Observability
LOG_LEVEL=INFO
OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_ENABLED=true
